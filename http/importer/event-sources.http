### Create Cassiopeia event source
# Requires a venue with the given ID to already exist in the database.
# The sourceType "CASSIOPEIA" matches EventSource.CASSIOPEIA.
# The URL points to the /club page where events are listed.
POST {{importer-host}}/api/admin/event-sources
Content-Type: application/json
Accept: application/json

{
    "venueId": 1,
    "name": "Cassiopeia",
    "url": "https://cassiopeia-berlin.de/club",
    "sourceType": "CASSIOPEIA",
    "enabled": true,
    "importIntervalMinutes": 1440,
    "maxRetries": 3
}

> {%
    client.test("should return 201", function () {
        client.assert(response.status === 201, "Expected 201 but got " + response.status);
    });
%}

