### --- Create Bi Nuu event source ---
# Links the venue to the BinuuWebsiteImporter.
# The sourceType "BINUU" matches EventSource.BINUU.
# NOTE: the URL is `/de/events` (the full program listing), NOT the homepage `/` —
# `/` 301-redirects to `/de` (only the next few events) and the scraper's WebClient
# does not follow redirects.
POST {{importer-host}}/api/admin/event-sources
Content-Type: application/json

{
    "venueId": {{binuu_venue_id}},
    "name": "Bi Nuu",
    "url": "https://binuu.de/de/events",
    "sourceType": "BINUU",
    "enabled": true,
    "importIntervalMinutes": 1440,
    "maxRetries": 3
}

> {%
    client.test("Bi Nuu event source created", function () {
        client.assert(response.status === 201, "Expected 201 but got " + response.status);
    });
%}

