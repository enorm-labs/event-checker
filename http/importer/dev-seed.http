### --- Create Madame Claude event source ---
# Links the venue to the MadameClaudeWebsiteImporter.
# The sourceType "MADAME_CLAUDE" matches EventSource.MADAME_CLAUDE.
# NOTE: the URL is the WordPress REST endpoint for the venue's `event` custom post type
# (ACF-backed), not the human `/events/` page. The importer appends the upcoming-only query
# (per_page/orderby/order/after/_embed) itself; the featured image is embedded via `_embed`.
POST {{importer-host}}/api/admin/event-sources
Content-Type: application/json

{
    "venueId": {{madame_claude_venue_id}},
    "name": "Madame Claude",
    "url": "https://madameclaude.de/wp-json/wp/v2/event",
    "sourceType": "MADAME_CLAUDE",
    "enabled": true,
    "importIntervalMinutes": 1440,
    "maxRetries": 3
}

> {%
    client.test("Madame Claude event source created", function () {
        client.assert(response.status === 201, "Expected 201 but got " + response.status);
    });
%}

### --- Trigger initial Madame Claude import ---
POST {{importer-host}}/api/admin/event-sources/madame-claude/import
Accept: application/json

> {%
