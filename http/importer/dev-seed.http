### --- Create SO36 event source ---
# Links the venue to the So36WebsiteImporter.
# The sourceType "SO36" matches EventSource.SO36.
# NOTE: the URL is `/tickets` (the program listing), NOT the homepage `/` —
# the homepage 302-redirects there and the scraper's WebClient does not follow redirects.
POST {{importer-host}}/api/admin/event-sources
Content-Type: application/json

{
    "venueId": {{so36_venue_id}},
    "name": "SO36",
    "url": "https://www.so36.com/tickets",
    "sourceType": "SO36",
    "enabled": true,
    "importIntervalMinutes": 1440,
    "maxRetries": 3
}

> {%
    client.test("SO36 event source created", function () {
        client.assert(response.status === 201, "Expected 201 but got " + response.status);
    });
%}

