### ============================================================
### Dev Seed — bootstrap local database with venues & sources
###
### Run all requests in this file sequentially (▶▶ "Run All")
### after starting the importer with a fresh database.
### Requests are idempotent-safe: duplicates will return 409.
###
### Sources:
###   1. Cassiopeia    — https://cassiopeia-berlin.de/club
###   2. Privatclub    — https://privatclub-berlin.de/
###   3. Madame Claude — https://madameclaude.de/events/
###   4. Astra         — https://www.astra-berlin.de/
###   5. Lido          — https://www.lido-berlin.de/
### ============================================================

### ————————————————————————————————————————————————————————————
### Cassiopeia (Revaler Str. 99, Berlin-Friedrichshain)
### ————————————————————————————————————————————————————————————

### --- Step 1: Create Cassiopeia venue ---
POST {{importer-host}}/api/admin/venues
Content-Type: application/json

{
    "name": "Cassiopeia",
    "address": "Revaler Str. 99",
    "city": "Berlin",
    "postalCode": "10245",
    "district": "friedrichshain-kreuzberg",
    "latitude": 52.50730,
    "longitude": 13.45414,
    "websiteUrl": "https://cassiopeia-berlin.de"
}

> {%
    client.global.set("cassiopeia_venue_id", response.body.id);
    client.test("Cassiopeia venue created", function () {
        client.assert(response.status === 201, "Expected 201 but got " + response.status);
    });
%}

### --- Step 2: Create Cassiopeia event source ---
# Links the venue to the CassiopeiaWebsiteImporter.
# The sourceType "CASSIOPEIA" matches EventSource.CASSIOPEIA.
POST {{importer-host}}/api/admin/event-sources
Content-Type: application/json

{
    "venueId": {{cassiopeia_venue_id}},
    "name": "Cassiopeia",
    "url": "https://cassiopeia-berlin.de/club",
    "sourceType": "CASSIOPEIA",
    "enabled": true,
    "importIntervalMinutes": 1440,
    "maxRetries": 3
}

> {%
    client.test("Cassiopeia event source created", function () {
        client.assert(response.status === 201, "Expected 201 but got " + response.status);
    });
%}

### --- Step 3: Trigger initial Cassiopeia import ---
POST {{importer-host}}/api/admin/event-sources/cassiopeia/import
Accept: application/json

> {%
    client.test("Cassiopeia import triggered", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
    });
%}

