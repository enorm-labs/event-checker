### --- Create Clash event source ---
# Links the venue to the ClashWebsiteImporter.
# The sourceType "CLASH" matches EventSource.CLASH.
# NOTE: the URL is the homepage `/` — all upcoming events are server-rendered inline in the
# `#events` section; the site has no per-event detail pages (the WP `event` post type is not
# exposed via the REST API, and the numeric `/events/<id>/` permalinks 404).
POST {{importer-host}}/api/admin/event-sources
Content-Type: application/json

{
    "venueId": {{clash_venue_id}},
    "name": "Clash",
    "url": "https://clash-berlin.de/",
    "sourceType": "CLASH",
    "enabled": true,
    "importIntervalMinutes": 1440,
    "maxRetries": 3
}

> {%
    client.test("Clash event source created", function () {
        client.assert(response.status === 201, "Expected 201 but got " + response.status);
    });
%}

