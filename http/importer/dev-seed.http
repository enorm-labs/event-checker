### --- Create Festsaal Kreuzberg event source ---
# Links the venue to the FestsaalWebsiteImporter.
# The sourceType "FESTSAAL" matches EventSource.FESTSAAL.
# NOTE: the public site (festsaal-kreuzberg.de) is a Nuxt.js SPA that renders no event
# data server-side. The URL is therefore the entry point of its Wagtail headless-CMS
# JSON REST API; the importer appends the EventPage query (type/fields/order) itself.
POST {{importer-host}}/api/admin/event-sources
Content-Type: application/json

{
    "venueId": {{festsaal_venue_id}},
    "name": "Festsaal Kreuzberg",
    "url": "https://admin.festsaal-kreuzberg.de/api/v2/pages/",
    "sourceType": "FESTSAAL",
    "enabled": true,
    "importIntervalMinutes": 1440,
    "maxRetries": 3
}

> {%
    client.test("Festsaal Kreuzberg event source created", function () {
        client.assert(response.status === 201, "Expected 201 but got " + response.status);
    });
%}

### --- Trigger initial Festsaal Kreuzberg import ---
# Slug is derived from the source name: "Festsaal Kreuzberg" → festsaal-kreuzberg.
