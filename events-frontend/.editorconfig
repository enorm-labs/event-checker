[*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,vue,css,scss,sass,less,styl}]
charset = utf-8
indent_size = 2
indent_style = space
# Override the root .editorconfig's continuation_indent_size = 8 (sized for the
# 4-space Kotlin backend). oxfmt wraps with a single 2-space level, including
# wrapped HTML/Vue attributes.
ij_continuation_indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf
max_line_length = 100

# Align IntelliJ's native formatter with oxfmt (.oxfmtrc.json). oxfmt ignores
# these ij_* keys; they only steer IntelliJ. Note: IntelliJ's line-wrapping
# engine differs from oxfmt's, so long lines that wrap may still diverge.
# oxfmt singleQuote: true
ij_javascript_use_double_quotes = false
ij_typescript_use_double_quotes = false
# oxfmt semi: false
ij_javascript_use_semicolon_after_statement = false
ij_javascript_force_semicolon_style = true
ij_typescript_use_semicolon_after_statement = false
ij_typescript_force_semicolon_style = true
# oxfmt trailingComma: "all" (default)
ij_javascript_enforce_trailing_comma = whenmultiline
ij_typescript_enforce_trailing_comma = whenmultiline
# oxfmt bracketSpacing: true (default) — object literals and ES6 import/export
# braces. spaces_within_imports is a separate key from the object-literal one.
ij_javascript_spaces_within_object_literal_braces = true
ij_typescript_spaces_within_object_literal_braces = true
ij_javascript_spaces_within_imports = true
ij_typescript_spaces_within_imports = true

# Vue template formatting uses IntelliJ's HTML engine. The root .editorconfig
# sets ij_html_space_inside_empty_tag = false (for the XML/Kotlin side), which
# makes IntelliJ emit <RouterView/>. oxfmt emits <RouterView /> with a space, so
# override it here for .vue files.
[*.vue]
ij_html_space_inside_empty_tag = true
